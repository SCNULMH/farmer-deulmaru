# Copy this file to .env and fill values for local development.
APP_SECRET_KEY=change-this-for-local-demo
USE_DEMO_DATA=true
DATABASE_BACKEND=sqlite

# Existing Spring keys should be moved here, not hard-coded in source code.
SUPPORT_API_BASE_URL=https://apis.data.go.kr/1390000/youngV2
SUPPORT_API_SERVICE_KEY=
NCPMS_API_BASE_URL=http://ncpms.rda.go.kr/npmsAPI/service
NCPMS_API_KEY=
NONGSARO_API_KEY=
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=http://127.0.0.1:8000/auth/kakao/callback

# Firebase / Firestore
# Set DATABASE_BACKEND=firebase to store users, interests, and diagnosis history in Firestore.
# Option A: paste the service-account JSON as a single env value on Render.
FIREBASE_CREDENTIALS_JSON=
# Option B: point to a local service-account file path.
GOOGLE_APPLICATION_CREDENTIALS=
